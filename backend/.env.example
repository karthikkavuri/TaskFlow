# MongoDB Atlas Connection String (REQUIRED)
# Must be a MongoDB Atlas connection string starting with mongodb+srv://
# Get this from your MongoDB Atlas dashboard -> Connect -> Connect your application
MONGO_URI=mongodb+srv://<username>:<password>@<cluster-url>/<database-name>?retryWrites=true&w=majority

# Server Configuration
PORT=5000
NODE_ENV=development

# JWT Configuration
JWT_SECRET=your_jwt_secret_key_here_change_this_in_production
JWT_EXPIRE=7d

# Email Configuration (for OTP verification)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_app_password

# IMPORTANT NOTES:
# 1. This backend only supports MongoDB Atlas (cloud MongoDB)
# 2. Local MongoDB connections are not supported
# 3. Ensure your IP is whitelisted in Atlas Network Access
# 4. Make sure your database user has read/write permissions
